# Application
ENV=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# HTTP
# Comma-separated list of allowed origins for CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Database (async driver)
# Examples:
#   postgresql+asyncpg://user:pass@localhost:5432/arabic_bot
#   postgresql+asyncpg://user:pass@host:5432/arabic_bot?ssl=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arabic_bot

# Server
HOST=0.0.0.0
PORT=8080
