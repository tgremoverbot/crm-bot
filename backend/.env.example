# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Database
#
# Production: Supabase Supavisor TRANSACTION pooler (port 6543).
# Cloud Run scales horizontally; transaction-mode pooling keeps connection
# counts within Supabase free-tier limits.
#
# Where to find this URL:
#   Supabase dashboard → project → Settings → Database
#   → Connection string → Transaction pooler (port 6543) → URI tab
#   Replace "postgresql://" with "postgresql+asyncpg://".
#
# NEVER use the Supabase anon key or service_role key here.
# NEVER expose DATABASE_URL to the frontend.
# -----------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Local alternative:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arabic_bot

# Connection pool — conservative sizing for Cloud Run.
# Each instance holds at most DB_POOL_SIZE + DB_MAX_OVERFLOW connections.
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------
# Telegram
#
# TELEGRAM_BOT_TOKEN  — from @BotFather.  Never commit. Use Secret Manager.
# TELEGRAM_WEBHOOK_SECRET — random 32+ char string sent in the
#   X-Telegram-Bot-Api-Secret-Token header by Telegram to verify every
#   incoming webhook request.  Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_WEBHOOK_SECRET=

# -----------------------------------------------------------------------
# JWT admin auth
#
# JWT_SECRET must be at least 32 random characters in production.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars!!
JWT_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------
# Internal scheduler endpoint
#
# Any Cloud Scheduler job calling POST /internal/process-scheduled must
# supply this key in the X-Internal-Api-Key header.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------
INTERNAL_API_KEY=

# -----------------------------------------------------------------------
# CORS — set to the GitHub Pages URL in production.
# Comma-separated list is supported: FRONTEND_ORIGIN=https://a.io,https://b.io
# -----------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------
# HTTP server
# Cloud Run injects PORT automatically; 8080 is the correct default.
# -----------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# -----------------------------------------------------------------------
# Scheduler
# -----------------------------------------------------------------------
SCHEDULER_MAX_MESSAGES=100
