# Application
ENV=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# HTTP
# Comma-separated list of allowed origins for CORS.
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------
# Database
#
# Production: Supabase Supavisor TRANSACTION pooler (port 6543).
# Cloud Run scales horizontally, so a transaction-mode pooler is required.
#
# Where to find this URL:
#   Supabase dashboard → your project → Settings → Database
#   → Connection string → Transaction pooler (port 6543) → URI tab
#   Prepend "postgresql+asyncpg://" in place of "postgresql://".
#
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# Local Postgres (docker-compose or local install):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arabic_bot
#
# NEVER use the Supabase anon key or service role key here.
# NEVER expose DATABASE_URL to the frontend.
# -----------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arabic_bot

# Connection pool — conservative sizing for Cloud Run.
# Each Cloud Run instance holds at most DB_POOL_SIZE + DB_MAX_OVERFLOW connections.
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=3
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800

# Server
HOST=0.0.0.0
PORT=8080
